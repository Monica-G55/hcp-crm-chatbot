# Rename this file to .env and fill in your values

# Groq API key - create a new one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Database URL - Postgres or MySQL
# Postgres example:
DATABASE_URL=postgresql://postgres:password@localhost:5432/hcp_crm
# MySQL example (comment above, uncomment below):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hcp_crm
